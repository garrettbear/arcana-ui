      "shadow": "{semantic.elevation.card}",
      "shadow-hover": "{semantic.elevation.card-hover}"
    },
    "modal": {
      "shadow": "{semantic.elevation.modal}",
      "overlay-bg": "{semantic.color.background.overlay}",
      "radius": "{semantic.radius.none}"
