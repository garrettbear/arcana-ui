{
  "$schema": "../schema/tokens.schema.json",
  "name": "arcana-brutalist",
  "version": "0.1.0",
  "description": "Raw brutalism — black and white, heavy borders, no curves",

  "primitive": {
    "color": {
      "white": "#ffffff",
      "black": "#000000",
      "transparent": "transparent",
      "gray": {
        "50": "#f8f8f8",
        "100": "#f0f0f0",
        "200": "#e0e0e0",
        "300": "#cccccc",
        "400": "#aaaaaa",
        "500": "#888888",
        "600": "#666666",
        "700": "#444444",
        "800": "#333333",
        "900": "#222222",
        "950": "#111111"
      },
      "red": {
        "50": "#fff0f0",
        "100": "#ffe0e0",
        "200": "#ffbbbb",
        "300": "#ff8888",
        "400": "#ff4444",
        "500": "#ff0000",
        "600": "#cc0000",
        "700": "#990000",
        "800": "#770000",
        "900": "#550000",
        "950": "#330000"
      },
      "blue": {
        "50": "#f0f0ff",
        "100": "#e0e0ff",
        "200": "#bbbbff",
        "300": "#8888ff",
        "400": "#4444ff",
        "500": "#0000ff",
        "600": "#0000cc",
        "700": "#000099",
        "800": "#000077",
        "900": "#000055",
        "950": "#000033"
      },
      "green": {
        "50": "#f0fff0",
        "100": "#e0ffe0",
        "200": "#bbffbb",
        "300": "#88ff88",
        "400": "#44cc44",
        "500": "#008800",
        "600": "#006600",
        "700": "#004400",
        "800": "#003300",
        "900": "#002200",
        "950": "#001100"
      },
      "amber": {
        "50": "#fffff0",
        "100": "#ffffe0",
        "200": "#ffffbb",
        "300": "#ffee88",
        "400": "#ddcc00",
        "500": "#998800",
        "600": "#886600",
        "700": "#664400",
        "800": "#553300",
        "900": "#442200",
        "950": "#221100"
      }
    },
    "spacing": {
      "0": "0",
      "px": "1px",
      "0.5": "0.125rem",
      "1": "0.25rem",
      "1.5": "0.375rem",
      "2": "0.5rem",
      "2.5": "0.625rem",
      "3": "0.75rem",
      "3.5": "0.875rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "7": "1.75rem",
      "8": "2rem",
      "9": "2.25rem",
      "10": "2.5rem",
      "11": "2.75rem",
      "12": "3rem",
      "14": "3.5rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "28": "7rem",
      "32": "8rem",
      "36": "9rem",
      "40": "10rem",
      "44": "11rem",
      "48": "12rem"
    },
    "radius": {
      "none": "0",
      "xs": "0",
      "sm": "0",
      "md": "0",
      "lg": "0",
      "xl": "0",
      "2xl": "0",
      "full": "9999px"
    },
    "typography": {
      "fontFamily": {
        "display": "'Space Grotesk', 'Inter', system-ui, sans-serif",
        "sans": "'Space Grotesk', 'Inter', system-ui, sans-serif",
        "mono": "'Space Mono', 'JetBrains Mono', monospace"
      },
      "fontSize": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem",
        "3xl": "1.875rem",
        "4xl": "2.25rem",
        "5xl": "3rem",
        "6xl": "3.75rem",
        "7xl": "4.5rem"
      },
      "fontWeight": {
        "light": "300",
        "normal": "400",
        "medium": "500",
        "semibold": "600",
        "bold": "700",
        "black": "900"
      },
      "lineHeight": {
        "none": "1",
        "tight": "1.25",
        "snug": "1.375",
        "normal": "1.5",
        "relaxed": "1.625",
        "loose": "1.75"
      },
      "letterSpacing": {
        "tighter": "-0.05em",
        "tight": "-0.025em",
        "normal": "0",
        "wide": "0.025em",
        "wider": "0.05em",
        "widest": "0.1em"
      }
    },
    "shadow": {
      "none": "none",
      "xs": "2px 2px 0 #000000",
      "sm": "3px 3px 0 #000000",
      "md": "4px 4px 0 #000000",
      "lg": "6px 6px 0 #000000",
      "xl": "8px 8px 0 #000000",
      "2xl": "12px 12px 0 #000000",
      "inner": "inset 2px 2px 0 rgba(0, 0, 0, 0.2)"
    },
    "motion": {
      "duration": {
        "instant": "0ms",
        "fast": "100ms",
        "normal": "150ms",
        "slow": "250ms",
        "slower": "400ms"
      },
      "easing": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "in": "cubic-bezier(0.4, 0, 1, 1)",
        "out": "cubic-bezier(0, 0, 0.2, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    },
    "zIndex": {
      "base": "0",
      "raised": "10",
      "dropdown": "100",
      "sticky": "200",
      "overlay": "300",
      "modal": "400",
      "toast": "500",
      "tooltip": "600"
    }
  },

  "semantic": {
    "color": {
      "background": {
        "page": "{primitive.color.white}",
        "surface": "{primitive.color.gray.100}",
        "elevated": "{primitive.color.white}",
        "overlay": "rgba(0, 0, 0, 0.8)",
        "sunken": "{primitive.color.gray.50}",
        "subtle": "{primitive.color.gray.200}"
      },
      "foreground": {
        "primary": "{primitive.color.black}",
        "secondary": "{primitive.color.gray.800}",
        "muted": "{primitive.color.gray.600}",
        "disabled": "{primitive.color.gray.400}",
        "inverse": "{primitive.color.white}",
        "on-primary": "{primitive.color.white}",
        "on-destructive": "{primitive.color.white}",
        "link": "{primitive.color.blue.500}",
        "link-hover": "{primitive.color.blue.600}"
      },
      "action": {
        "primary": {
          "default": "{primitive.color.black}",
          "hover": "{primitive.color.gray.900}",
          "active": "{primitive.color.gray.800}",
          "disabled": "{primitive.color.gray.400}"
        },
        "secondary": {
          "default": "{primitive.color.white}",
          "hover": "{primitive.color.gray.100}",
          "active": "{primitive.color.gray.200}"
        },
        "destructive": {
          "default": "{primitive.color.red.500}",
          "hover": "{primitive.color.red.600}",
          "active": "{primitive.color.red.700}"
        },
        "ghost": {
          "default": "{primitive.color.transparent}",
          "hover": "rgba(0, 0, 0, 0.05)",
          "active": "rgba(0, 0, 0, 0.1)"
        },
        "outline": {
          "default": "{primitive.color.transparent}",
          "hover": "rgba(0, 0, 0, 0.05)",
          "active": "rgba(0, 0, 0, 0.1)"
        }
      },
      "border": {
        "default": "{primitive.color.black}",
        "muted": "{primitive.color.gray.300}",
        "strong": "{primitive.color.black}",
        "stronger": "{primitive.color.black}",
        "focus": "{primitive.color.blue.500}",
        "error": "{primitive.color.red.500}",
        "success": "{primitive.color.green.500}",
        "inverse": "{primitive.color.white}"
      },
      "status": {
        "success": {
          "default": "{primitive.color.green.500}",
          "bg": "{primitive.color.green.50}",
          "fg": "{primitive.color.green.700}",
          "border": "{primitive.color.black}"
        },
        "warning": {
          "default": "{primitive.color.amber.500}",
          "bg": "{primitive.color.amber.50}",
          "fg": "{primitive.color.amber.700}",
          "border": "{primitive.color.black}"
        },
        "error": {
          "default": "{primitive.color.red.500}",
          "bg": "{primitive.color.red.50}",
          "fg": "{primitive.color.red.700}",
          "border": "{primitive.color.red.500}"
        },
        "info": {
          "default": "{primitive.color.blue.500}",
          "bg": "{primitive.color.blue.50}",
          "fg": "{primitive.color.blue.700}",
          "border": "{primitive.color.black}"
        }
      },
      "accent": {
        "primary": "{primitive.color.black}",
        "secondary": "{primitive.color.red.500}"
      }
    },
    "typography": {
      "family": {
        "display": "{primitive.typography.fontFamily.display}",
        "body": "{primitive.typography.fontFamily.sans}",
        "mono": "{primitive.typography.fontFamily.mono}"
      },
      "size": {
        "xs": "{primitive.typography.fontSize.xs}",
        "sm": "{primitive.typography.fontSize.sm}",
        "base": "{primitive.typography.fontSize.base}",
        "lg": "clamp(1rem, 0.958rem + 0.208vw, 1.125rem)",
        "xl": "clamp(1.125rem, 1.083rem + 0.208vw, 1.25rem)",
        "2xl": "clamp(1.25rem, 1.167rem + 0.417vw, 1.5rem)",
        "3xl": "clamp(1.5rem, 1.375rem + 0.625vw, 1.875rem)",
        "4xl": "clamp(1.75rem, 1.583rem + 0.833vw, 2.25rem)",
        "5xl": "clamp(2rem, 1.667rem + 1.667vw, 3rem)",
        "6xl": "clamp(2.5rem, 2.083rem + 2.083vw, 3.75rem)",
        "7xl": "clamp(3rem, 2.5rem + 2.5vw, 4.5rem)"
      },
      "weight": {
        "heading": "{primitive.typography.fontWeight.black}",
        "body": "{primitive.typography.fontWeight.normal}",
        "strong": "{primitive.typography.fontWeight.bold}",
        "ui": "{primitive.typography.fontWeight.semibold}"
      },
      "lineHeight": {
        "heading": "{primitive.typography.lineHeight.none}",
        "body": "{primitive.typography.lineHeight.normal}",
        "ui": "{primitive.typography.lineHeight.tight}"
      },
      "letterSpacing": {
        "heading": "{primitive.typography.letterSpacing.tighter}",
        "body": "{primitive.typography.letterSpacing.normal}",
        "caps": "{primitive.typography.letterSpacing.widest}"
      },
      "paragraphSpacing": "1.25em"
    },
    "spacing": {
      "xs": "{primitive.spacing.1}",
      "sm": "{primitive.spacing.2}",
      "md": "{primitive.spacing.4}",
      "lg": "{primitive.spacing.6}",
      "xl": "{primitive.spacing.8}",
      "2xl": "{primitive.spacing.12}",
      "3xl": "{primitive.spacing.16}",
      "section": "{primitive.spacing.24}",
      "section-lg": "{primitive.spacing.32}"
    },
    "elevation": {
      "none": "{primitive.shadow.none}",
      "xs": "{primitive.shadow.xs}",
      "sm": "{primitive.shadow.sm}",
      "md": "{primitive.shadow.md}",
      "lg": "{primitive.shadow.lg}",
      "xl": "{primitive.shadow.xl}",
      "2xl": "{primitive.shadow.2xl}",
      "inner": "{primitive.shadow.inner}"
    },
    "radius": {
      "none": "{primitive.radius.none}",
      "xs": "{primitive.radius.xs}",
      "sm": "{primitive.radius.sm}",
      "md": "{primitive.radius.md}",
      "lg": "{primitive.radius.lg}",
      "xl": "{primitive.radius.xl}",
      "2xl": "{primitive.radius.2xl}",
      "full": "{primitive.radius.full}"
    },
    "border": {
      "width": {
        "thin": "2px",
        "default": "3px",
        "thick": "4px"
      },
      "focus": {
        "ring": "0 0 0 3px rgba(0, 0, 255, 0.3)",
        "ringError": "0 0 0 3px rgba(255, 0, 0, 0.3)",
        "offset": "2px"
      }
    },
    "motion": {
      "duration": {
        "instant": "{primitive.motion.duration.instant}",
        "fast": "{primitive.motion.duration.fast}",
        "normal": "{primitive.motion.duration.normal}",
        "slow": "{primitive.motion.duration.slow}",
        "slower": "{primitive.motion.duration.slower}"
      },
      "easing": {
        "default": "{primitive.motion.easing.default}",
        "in": "{primitive.motion.easing.in}",
        "out": "{primitive.motion.easing.out}",
        "spring": "{primitive.motion.easing.spring}"
      }
    }
  },

  "component": {
    "button": {
      "radius": "{semantic.radius.none}",
      "border-width": "{semantic.border.width.default}",
      "bg": "{semantic.color.action.primary.default}",
      "fg": "{semantic.color.foreground.on-primary}",
      "border-color": "{semantic.color.border.default}",
      "font-size": "{primitive.typography.fontSize.sm}",
      "font-weight": "{primitive.typography.fontWeight.bold}",
      "letter-spacing": "{primitive.typography.letterSpacing.wide}",
      "padding-x": "var(--spacing-md)",
      "padding-y": "var(--spacing-sm)"
    },
    "input": {
      "radius": "{semantic.radius.none}",
      "border-width": "{semantic.border.width.default}",
      "bg": "{semantic.color.background.page}",
      "fg": "{semantic.color.foreground.primary}",
      "border-color": "{semantic.color.border.default}",
      "border-focus": "{semantic.color.border.focus}",
      "border-error": "{semantic.color.border.error}",
      "font-size": "{primitive.typography.fontSize.sm}",
      "padding-x": "var(--spacing-sm)"
    },
    "card": {
      "radius": "{semantic.radius.none}",
      "border-width": "{semantic.border.width.default}",
      "bg": "{semantic.color.background.surface}",
      "border-color": "{semantic.color.border.default}",
      "padding": "var(--spacing-lg)"
    }
  }
}
