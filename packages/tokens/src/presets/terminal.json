{
  "$schema": "../schema/tokens.schema.json",
  "name": "arcana-terminal",
  "version": "0.1.0",
  "description": "Hacker terminal — green phosphor on deep dark",

  "primitive": {
    "color": {
      "white": "#ffffff",
      "black": "#000000",
      "transparent": "transparent",
      "gray": {
        "50": "#f9fafb",
        "100": "#f3f4f6",
        "200": "#e5e7eb",
        "300": "#d1d5db",
        "400": "#9ca3af",
        "500": "#6b7280",
        "600": "#4b5563",
        "700": "#374151",
        "800": "#1f2937",
        "900": "#111827",
        "950": "#030712"
      },
      "green": {
        "50": "#f0fdf4",
        "100": "#dcfce7",
        "200": "#bbf7d0",
        "300": "#86efac",
        "400": "#4ade80",
        "500": "#22c55e",
        "600": "#16a34a",
        "700": "#15803d",
        "800": "#166534",
        "900": "#14532d",
        "950": "#052e16"
      }
    },
    "spacing": {
      "0": "0",
      "px": "1px",
      "0.5": "0.125rem",
      "1": "0.25rem",
      "1.5": "0.375rem",
      "2": "0.5rem",
      "2.5": "0.625rem",
      "3": "0.75rem",
      "3.5": "0.875rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "7": "1.75rem",
      "8": "2rem",
      "9": "2.25rem",
      "10": "2.5rem",
      "11": "2.75rem",
      "12": "3rem",
      "14": "3.5rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "28": "7rem",
      "32": "8rem",
      "36": "9rem",
      "40": "10rem",
      "44": "11rem",
      "48": "12rem"
    },
    "radius": {
      "none": "0",
      "xs": "0",
      "sm": "0",
      "md": "0",
      "lg": "0",
      "xl": "0",
      "2xl": "0",
      "full": "9999px"
    },
    "typography": {
      "fontFamily": {
        "display": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
        "sans": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
        "mono": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace"
      },
      "fontSize": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem",
        "3xl": "1.875rem",
        "4xl": "2.25rem",
        "5xl": "3rem",
        "6xl": "3.75rem",
        "7xl": "4.5rem"
      },
      "fontWeight": {
        "light": "300",
        "normal": "400",
        "medium": "500",
        "semibold": "600",
        "bold": "700",
        "black": "900"
      },
      "lineHeight": {
        "none": "1",
        "tight": "1.25",
        "snug": "1.375",
        "normal": "1.5",
        "relaxed": "1.625",
        "loose": "1.75"
      },
      "letterSpacing": {
        "tighter": "-0.05em",
        "tight": "-0.025em",
        "normal": "0",
        "wide": "0.025em",
        "wider": "0.05em",
        "widest": "0.1em"
      }
    },
    "shadow": {
      "none": "none",
      "xs": "none",
      "sm": "none",
      "md": "none",
      "lg": "none",
      "xl": "none",
      "2xl": "none",
      "inner": "none"
    },
    "blur": {
      "none": "0",
      "sm": "0",
      "md": "0",
      "lg": "0",
      "xl": "0",
      "2xl": "0",
      "3xl": "0"
    },
    "motion": {
      "duration": {
        "instant": "0ms",
        "fast": "100ms",
        "normal": "150ms",
        "slow": "250ms",
        "slower": "400ms"
      },
      "easing": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "in": "cubic-bezier(0.4, 0, 1, 1)",
        "out": "cubic-bezier(0, 0, 0.2, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    },
    "zIndex": {
      "base": "0",
      "raised": "10",
      "dropdown": "100",
      "sticky": "200",
      "fixed": "300",
      "overlay": "400",
      "modal": "500",
      "popover": "600",
      "toast": "700",
      "tooltip": "800"
    },
    "layout": {
      "breakpoint-sm": "640px",
      "breakpoint-md": "768px",
      "breakpoint-lg": "1024px",
      "breakpoint-xl": "1280px",
      "breakpoint-2xl": "1536px",
      "container-sm": "640px",
      "container-md": "768px",
      "container-lg": "1024px",
      "container-xl": "1280px",
      "container-2xl": "1536px",
      "content-prose": "65ch",
      "content-narrow": "42rem",
      "content-default": "56rem",
      "content-wide": "72rem",
      "content-full": "100%",
      "grid-columns": "12"
    }
  },

  "semantic": {
    "color": {
      "background": {
        "page": "{primitive.color.black}",
        "surface": "{primitive.color.gray.950}",
        "elevated": "{primitive.color.gray.900}",
        "overlay": "rgba(0, 0, 0, 0.85)",
        "sunken": "{primitive.color.black}",
        "subtle": "{primitive.color.gray.900}"
      },
      "foreground": {
        "primary": "{primitive.color.green.400}",
        "secondary": "{primitive.color.green.500}",
        "muted": "{primitive.color.green.700}",
        "disabled": "{primitive.color.green.900}",
        "inverse": "{primitive.color.black}",
        "on-primary": "{primitive.color.black}",
        "on-destructive": "{primitive.color.white}",
        "link": "{primitive.color.green.300}",
        "link-hover": "{primitive.color.green.200}"
      },
      "action": {
        "primary": {
          "default": "{primitive.color.green.500}",
          "hover": "{primitive.color.green.400}",
          "active": "{primitive.color.green.600}",
          "disabled": "{primitive.color.green.800}"
        },
        "secondary": {
          "default": "{primitive.color.gray.800}",
          "hover": "{primitive.color.gray.700}",
          "active": "{primitive.color.gray.600}"
        },
        "destructive": {
          "default": "#f85149",
          "hover": "#da3633",
          "active": "#b62324"
        },
        "ghost": {
          "default": "{primitive.color.transparent}",
          "hover": "rgba(57, 211, 83, 0.1)",
          "active": "rgba(57, 211, 83, 0.15)"
        },
        "outline": {
          "default": "{primitive.color.transparent}",
          "hover": "rgba(57, 211, 83, 0.08)",
          "active": "rgba(57, 211, 83, 0.15)"
        }
      },
      "border": {
        "default": "{primitive.color.gray.800}",
        "muted": "{primitive.color.gray.900}",
        "strong": "{primitive.color.gray.700}",
        "stronger": "{primitive.color.gray.600}",
        "focus": "{primitive.color.green.400}",
        "error": "#f85149",
        "success": "{primitive.color.green.400}",
        "inverse": "{primitive.color.green.400}"
      },
      "status": {
        "success": {
          "default": "{primitive.color.green.400}",
          "bg": "rgba(63, 185, 80, 0.12)",
          "fg": "{primitive.color.green.300}",
          "border": "rgba(63, 185, 80, 0.3)"
        },
        "warning": {
          "default": "#d29922",
          "bg": "rgba(210, 153, 34, 0.12)",
          "fg": "#e3b341",
          "border": "rgba(210, 153, 34, 0.3)"
        },
        "error": {
          "default": "#f85149",
          "bg": "rgba(248, 81, 73, 0.12)",
          "fg": "#ff7b72",
          "border": "rgba(248, 81, 73, 0.3)"
        },
        "info": {
          "default": "{primitive.color.green.300}",
          "bg": "rgba(57, 211, 83, 0.12)",
          "fg": "{primitive.color.green.200}",
          "border": "rgba(57, 211, 83, 0.3)"
        }
      },
      "accent": {
        "primary": "{primitive.color.green.400}",
        "secondary": "{primitive.color.green.300}"
      }
    },
    "typography": {
      "family": {
        "display": "{primitive.typography.fontFamily.mono}",
        "body": "{primitive.typography.fontFamily.mono}",
        "mono": "{primitive.typography.fontFamily.mono}"
      },
      "size": {
        "xs": "{primitive.typography.fontSize.xs}",
        "sm": "{primitive.typography.fontSize.sm}",
        "base": "{primitive.typography.fontSize.base}",
        "lg": "clamp(1rem, 0.958rem + 0.208vw, 1.125rem)",
        "xl": "clamp(1.125rem, 1.083rem + 0.208vw, 1.25rem)",
        "2xl": "clamp(1.25rem, 1.167rem + 0.417vw, 1.5rem)",
        "3xl": "clamp(1.5rem, 1.375rem + 0.625vw, 1.875rem)",
        "4xl": "clamp(1.75rem, 1.583rem + 0.833vw, 2.25rem)",
        "5xl": "clamp(2rem, 1.667rem + 1.667vw, 3rem)",
        "6xl": "clamp(2.5rem, 2.083rem + 2.083vw, 3.75rem)",
        "7xl": "clamp(3rem, 2.5rem + 2.5vw, 4.5rem)"
      },
      "weight": {
        "heading": "{primitive.typography.fontWeight.bold}",
        "body": "{primitive.typography.fontWeight.normal}",
        "strong": "{primitive.typography.fontWeight.bold}",
        "ui": "{primitive.typography.fontWeight.normal}"
      },
      "lineHeight": {
        "heading": "{primitive.typography.lineHeight.snug}",
        "body": "{primitive.typography.lineHeight.relaxed}",
        "ui": "{primitive.typography.lineHeight.normal}"
      },
      "letterSpacing": {
        "heading": "{primitive.typography.letterSpacing.normal}",
        "body": "{primitive.typography.letterSpacing.normal}",
        "caps": "{primitive.typography.letterSpacing.widest}"
      },
      "paragraphSpacing": "1.5em"
    },
    "spacing": {
      "xs": "{primitive.spacing.0.5}",
      "sm": "{primitive.spacing.1}",
      "md": "{primitive.spacing.2}",
      "lg": "{primitive.spacing.3}",
      "xl": "{primitive.spacing.5}",
      "2xl": "{primitive.spacing.8}",
      "3xl": "{primitive.spacing.12}",
      "section": "{primitive.spacing.16}",
      "section-lg": "{primitive.spacing.24}"
    },
    "elevation": {
      "none": "{primitive.shadow.none}",
      "xs": "{primitive.shadow.xs}",
      "sm": "{primitive.shadow.sm}",
      "md": "{primitive.shadow.md}",
      "lg": "{primitive.shadow.lg}",
      "xl": "{primitive.shadow.xl}",
      "2xl": "{primitive.shadow.2xl}",
      "inner": "{primitive.shadow.inner}",
      "card": "{primitive.shadow.none}",
      "card-hover": "{primitive.shadow.none}",
      "dropdown": "{primitive.shadow.none}",
      "modal": "{primitive.shadow.none}",
      "popover": "{primitive.shadow.none}",
      "toast": "{primitive.shadow.none}",
      "navbar": "{primitive.shadow.none}",
      "sidebar": "{primitive.shadow.none}"
    },
    "layout": {
      "breakpoint-sm": "{primitive.layout.breakpoint-sm}",
      "breakpoint-md": "{primitive.layout.breakpoint-md}",
      "breakpoint-lg": "{primitive.layout.breakpoint-lg}",
      "breakpoint-xl": "{primitive.layout.breakpoint-xl}",
      "breakpoint-2xl": "{primitive.layout.breakpoint-2xl}",
      "container-sm": "{primitive.layout.container-sm}",
      "container-md": "{primitive.layout.container-md}",
      "container-lg": "{primitive.layout.container-lg}",
      "container-xl": "{primitive.layout.container-xl}",
      "container-2xl": "{primitive.layout.container-2xl}",
      "content-prose": "{primitive.layout.content-prose}",
      "content-narrow": "{primitive.layout.content-narrow}",
      "content-default": "{primitive.layout.content-default}",
      "content-wide": "{primitive.layout.content-wide}",
      "content-full": "{primitive.layout.content-full}",
      "grid-columns": "{primitive.layout.grid-columns}",
      "grid-gutter": "var(--spacing-sm)",
      "grid-gutter-sm": "var(--spacing-xs)",
      "grid-gutter-lg": "var(--spacing-md)",
      "grid-margin": "var(--spacing-sm)",
      "grid-margin-lg": "var(--spacing-md)"
    },
    "radius": {
      "none": "{primitive.radius.none}",
      "xs": "{primitive.radius.xs}",
      "sm": "{primitive.radius.sm}",
      "md": "{primitive.radius.md}",
      "lg": "{primitive.radius.lg}",
      "xl": "{primitive.radius.xl}",
      "2xl": "{primitive.radius.2xl}",
      "full": "{primitive.radius.full}"
    },
    "border": {
      "width": {
        "thin": "1px",
        "default": "1px",
        "thick": "2px"
      },
      "focus": {
        "ring": "0 0 0 3px rgba(57, 211, 83, 0.4)",
        "ringError": "0 0 0 3px rgba(239, 68, 68, 0.3)",
        "offset": "2px"
      }
    },
    "motion": {
      "duration": {
        "instant": "{primitive.motion.duration.instant}",
        "fast": "{primitive.motion.duration.fast}",
        "normal": "{primitive.motion.duration.normal}",
        "slow": "{primitive.motion.duration.slow}",
        "slower": "{primitive.motion.duration.slower}"
      },
      "easing": {
        "default": "{primitive.motion.easing.default}",
        "in": "{primitive.motion.easing.in}",
        "out": "{primitive.motion.easing.out}",
        "spring": "{primitive.motion.easing.spring}"
      }
    }
  },

  "component": {
    "button": {
      "radius": "{semantic.radius.none}",
      "border-width": "{semantic.border.width.default}",
      "bg": "{semantic.color.action.primary.default}",
      "fg": "{semantic.color.foreground.on-primary}",
      "border-color": "{semantic.color.border.default}",
      "font-size": "{primitive.typography.fontSize.sm}",
      "font-weight": "{primitive.typography.fontWeight.normal}",
      "letter-spacing": "{primitive.typography.letterSpacing.wide}",
      "padding-x": "var(--spacing-md)",
      "padding-y": "var(--spacing-sm)"
    },
    "input": {
      "radius": "{semantic.radius.none}",
      "border-width": "{semantic.border.width.default}",
      "bg": "{semantic.color.background.page}",
      "fg": "{semantic.color.foreground.primary}",
      "border-color": "{semantic.color.border.default}",
      "border-focus": "{semantic.color.border.focus}",
      "border-error": "{semantic.color.border.error}",
      "font-size": "{primitive.typography.fontSize.sm}",
      "padding-x": "var(--spacing-sm)"
    },
    "card": {
      "radius": "{semantic.radius.none}",
      "border-width": "{semantic.border.width.default}",
      "bg": "{semantic.color.background.surface}",
      "border-color": "{semantic.color.border.default}",
      "padding": "var(--spacing-lg)",
      "shadow": "{semantic.elevation.card}",
      "shadow-hover": "{semantic.elevation.card-hover}"
    },
    "modal": {
      "shadow": "{semantic.elevation.modal}",
      "overlay-bg": "{semantic.color.background.overlay}"
    },
    "toast": {
      "shadow": "{semantic.elevation.toast}"
    },
    "navbar": {
      "shadow": "{semantic.elevation.navbar}",
      "backdrop-blur": "{primitive.blur.none}"
    }
  }
}
