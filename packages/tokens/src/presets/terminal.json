{
  "$schema": "../schema/tokens.schema.json",
  "name": "arcana-terminal",
  "version": "0.1.0",
  "description": "Hacker terminal — green phosphor on deep dark",

  "primitive": {
    "color": {
      "white": "#ffffff",
      "stone": {
        "50": "#fafaf9",
        "100": "#f5f5f4",
        "200": "#e7e5e4",
        "300": "#d6d3d1",
        "400": "#a8a29e",
        "500": "#78716c",
        "600": "#57534e",
        "700": "#44403c",
        "800": "#292524",
        "900": "#1c1917",
        "950": "#0c0a09"
      },
      "indigo": {
        "50": "#eef2ff",
        "100": "#e0e7ff",
        "400": "#818cf8",
        "500": "#6366f1",
        "600": "#4f46e5",
        "700": "#4338ca",
        "800": "#3730a3"
      },
      "amber": {
        "400": "#fbbf24",
        "500": "#f59e0b",
        "600": "#d97706"
      },
      "red": {
        "50": "#fef2f2",
        "100": "#fee2e2",
        "400": "#f87171",
        "500": "#ef4444",
        "600": "#dc2626",
        "700": "#b91c1c",
        "800": "#991b1b"
      },
      "green": {
        "50": "#f0fdf4",
        "100": "#dcfce7",
        "400": "#4ade80",
        "500": "#22c55e",
        "600": "#16a34a",
        "700": "#15803d",
        "800": "#166534"
      },
      "blue": {
        "50": "#eff6ff",
        "100": "#dbeafe",
        "400": "#60a5fa",
        "500": "#3b82f6",
        "600": "#2563eb",
        "700": "#1d4ed8"
      }
    },
    "spacing": {
      "0": "0",
      "px": "1px",
      "0.5": "0.125rem",
      "1": "0.25rem",
      "1.5": "0.375rem",
      "2": "0.5rem",
      "2.5": "0.625rem",
      "3": "0.75rem",
      "3.5": "0.875rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "7": "1.75rem",
      "8": "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "14": "3.5rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "32": "8rem"
    },
    "radius": {
      "none": "0",
      "xs": "0",
      "sm": "0",
      "md": "0",
      "lg": "0",
      "xl": "0",
      "2xl": "0",
      "full": "9999px"
    },
    "typography": {
      "fontFamily": {
        "sans": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
        "mono": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace"
      },
      "fontSize": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem",
        "3xl": "1.875rem",
        "4xl": "2.25rem",
        "5xl": "3rem"
      },
      "fontWeight": {
        "normal": "400",
        "medium": "500",
        "semibold": "600",
        "bold": "700"
      },
      "lineHeight": {
        "none": "1",
        "tight": "1.25",
        "snug": "1.375",
        "normal": "1.5",
        "relaxed": "1.625",
        "loose": "2"
      },
      "letterSpacing": {
        "tighter": "-0.05em",
        "tight": "-0.025em",
        "normal": "0",
        "wide": "0.025em",
        "wider": "0.05em",
        "widest": "0.1em"
      }
    },
    "shadow": {
      "none": "none",
      "xs": "none",
      "sm": "none",
      "md": "none",
      "lg": "none",
      "xl": "none",
      "2xl": "none",
      "inner": "none"
    },
    "motion": {
      "duration": {
        "instant": "0ms",
        "fast": "100ms",
        "normal": "150ms",
        "slow": "250ms",
        "slower": "400ms"
      },
      "easing": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "in": "cubic-bezier(0.4, 0, 1, 1)",
        "out": "cubic-bezier(0, 0, 0.2, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    },
    "zIndex": {
      "base": "0",
      "raised": "10",
      "dropdown": "100",
      "sticky": "200",
      "overlay": "300",
      "modal": "400",
      "toast": "500",
      "tooltip": "600"
    }
  },

  "semantic": {
    "color": {
      "background": {
        "page": "#0d1117",
        "surface": "#161b22",
        "elevated": "#1c2128",
        "overlay": "rgba(0, 0, 0, 0.85)",
        "sunken": "#010409",
        "subtle": "#21262d"
      },
      "foreground": {
        "primary": "#39d353",
        "secondary": "#2ea043",
        "muted": "#238636",
        "disabled": "#1a4022",
        "inverse": "#010409",
        "on-primary": "#010409",
        "on-destructive": "{primitive.color.white}",
        "link": "#58a6ff",
        "link-hover": "#79c0ff"
      },
      "action": {
        "primary": {
          "default": "#39d353",
          "hover": "#2ea043",
          "active": "#26a641"
        },
        "secondary": {
          "default": "#21262d",
          "hover": "#30363d",
          "active": "#3c434b"
        },
        "destructive": {
          "default": "#f85149",
          "hover": "#da3633",
          "active": "#b62324"
        },
        "ghost": {
          "default": "transparent",
          "hover": "rgba(57, 211, 83, 0.1)",
          "active": "rgba(57, 211, 83, 0.15)"
        },
        "outline": {
          "default": "transparent",
          "hover": "rgba(57, 211, 83, 0.08)",
          "active": "rgba(57, 211, 83, 0.15)"
        }
      },
      "border": {
        "default": "#21262d",
        "strong": "#30363d",
        "stronger": "#3d444d",
        "focus": "#39d353",
        "error": "#f85149",
        "inverse": "#39d353"
      },
      "status": {
        "success": {
          "default": "#3fb950",
          "bg": "rgba(63, 185, 80, 0.12)",
          "fg": "#7ee787",
          "border": "rgba(63, 185, 80, 0.3)"
        },
        "warning": {
          "default": "#d29922",
          "bg": "rgba(210, 153, 34, 0.12)",
          "fg": "#e3b341",
          "border": "rgba(210, 153, 34, 0.3)"
        },
        "error": {
          "default": "#f85149",
          "bg": "rgba(248, 81, 73, 0.12)",
          "fg": "#ff7b72",
          "border": "rgba(248, 81, 73, 0.3)"
        },
        "info": {
          "default": "#58a6ff",
          "bg": "rgba(88, 166, 255, 0.12)",
          "fg": "#79c0ff",
          "border": "rgba(88, 166, 255, 0.3)"
        }
      }
    },
    "typography": {
      "family": {
        "display": "{primitive.typography.fontFamily.mono}",
        "body": "{primitive.typography.fontFamily.mono}",
        "mono": "{primitive.typography.fontFamily.mono}"
      }
    },
    "spacing": {
      "xs": "{primitive.spacing.1}",
      "sm": "{primitive.spacing.2}",
      "md": "{primitive.spacing.4}",
      "lg": "{primitive.spacing.6}",
      "xl": "{primitive.spacing.8}",
      "2xl": "{primitive.spacing.12}",
      "3xl": "{primitive.spacing.16}",
      "section": "{primitive.spacing.24}"
    },
    "elevation": {
      "none": "{primitive.shadow.none}",
      "xs": "{primitive.shadow.xs}",
      "sm": "{primitive.shadow.sm}",
      "md": "{primitive.shadow.md}",
      "lg": "{primitive.shadow.lg}",
      "xl": "{primitive.shadow.xl}",
      "2xl": "{primitive.shadow.2xl}",
      "inner": "{primitive.shadow.inner}"
    },
    "radius": {
      "none": "{primitive.radius.none}",
      "xs": "{primitive.radius.xs}",
      "sm": "{primitive.radius.sm}",
      "md": "{primitive.radius.md}",
      "lg": "{primitive.radius.lg}",
      "xl": "{primitive.radius.xl}",
      "2xl": "{primitive.radius.2xl}",
      "full": "{primitive.radius.full}"
    },
    "border": {
      "width": {
        "thin": "1px",
        "default": "1px",
        "thick": "2px"
      },
      "focus": {
        "ring": "0 0 0 3px rgba(57, 211, 83, 0.4)",
        "ringError": "0 0 0 3px rgba(239, 68, 68, 0.3)",
        "offset": "2px"
      }
    },
    "motion": {
      "duration": {
        "instant": "{primitive.motion.duration.instant}",
        "fast": "{primitive.motion.duration.fast}",
        "normal": "{primitive.motion.duration.normal}",
        "slow": "{primitive.motion.duration.slow}",
        "slower": "{primitive.motion.duration.slower}"
      },
      "easing": {
        "default": "{primitive.motion.easing.default}",
        "in": "{primitive.motion.easing.in}",
        "out": "{primitive.motion.easing.out}",
        "spring": "{primitive.motion.easing.spring}"
      }
    }
  },

  "component": {
    "button": {
      "radius": "{semantic.radius.none}",
      "border-width": "{semantic.border.width.default}"
    },
    "input": {
      "radius": "{semantic.radius.none}",
      "border-width": "{semantic.border.width.default}"
    },
    "card": {
      "radius": "{semantic.radius.none}",
      "border-width": "{semantic.border.width.default}"
    }
  }
}
