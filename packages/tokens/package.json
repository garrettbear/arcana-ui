{
  "name": "@arcana-ui/tokens",
  "version": "0.1.0-beta.2",
  "description": "Design tokens for Arcana UI — AI's #1 design system",
  "license": "MIT",
  "main": "./dist/arcana.css",
  "exports": {
    ".": "./dist/arcana.css",
    "./base": "./dist/arcana.css",
    "./styles": "./dist/arcana.css",
    "./compat": "./dist/compat.css",
    "./light": "./dist/themes/light.css",
    "./dark": "./dist/themes/dark.css",
    "./terminal": "./dist/themes/terminal.css",
    "./retro98": "./dist/themes/retro98.css",
    "./glass": "./dist/themes/glass.css",
    "./brutalist": "./dist/themes/brutalist.css",
    "./corporate": "./dist/themes/corporate.css",
    "./startup": "./dist/themes/startup.css",
    "./editorial": "./dist/themes/editorial.css",
    "./commerce": "./dist/themes/commerce.css",
    "./midnight": "./dist/themes/midnight.css",
    "./nature": "./dist/themes/nature.css",
    "./neon": "./dist/themes/neon.css",
    "./mono": "./dist/themes/mono.css",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "npx tsx src/build.ts",
    "prepublishOnly": "pnpm build",
    "dev": "npx tsx --watch src/build.ts",
    "clean": "rm -rf dist",
    "validate": "npx tsx src/validate.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Arcana-UI/arcana"
  },
  "homepage": "https://arcana-design-system.vercel.app",
  "keywords": ["design-tokens", "css-custom-properties", "theming", "design-system", "ai"],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
