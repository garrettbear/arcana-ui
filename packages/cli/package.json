{
  "name": "@arcana-ui/cli",
  "version": "0.1.0-beta.1",
  "description": "Command-line tool for Arcana UI — scaffold projects, validate themes, manage presets",
  "license": "MIT",
  "type": "module",
  "bin": {
    "arcana-ui": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Arcana-UI/arcana",
    "directory": "packages/cli"
  },
  "homepage": "https://arcana-ui.com",
  "keywords": ["arcana", "arcana-ui", "cli", "scaffold", "design-system", "create-app"],
  "publishConfig": {
    "access": "public"
  }
}
