{
  "name": "arcana-ui",
  "private": true,
  "version": "0.0.0",
  "description": "AI-first design system with token-driven theming",
  "scripts": {
    "build": "pnpm -r --filter '!docs' build",
    "build:tokens": "pnpm --filter @arcana-ui/tokens build",
    "build:core": "pnpm --filter @arcana-ui/core build",
    "dev": "pnpm --filter playground dev",
    "lint": "biome check . && pnpm lint:tokens",
    "lint:tokens": "pnpm --filter @arcana-ui/tokens exec tsx src/lint-tokens.ts",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:all": "vitest run && playwright test",
    "validate:tokens": "pnpm --filter @arcana-ui/tokens validate",
    "generate-docs": "node scripts/generate-docs.mjs",
    "manifest": "node scripts/generate-manifest.mjs",
    "manifest:check": "node scripts/generate-manifest.mjs --check",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "dev:dashboard": "pnpm --filter @arcana-ui/demo-dashboard dev",
    "dev:ecommerce": "pnpm --filter @arcana-ui/demo-ecommerce dev",
    "dev:demos": "pnpm --filter '@arcana-ui/demo-*' dev",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": ["biome check --write --no-errors-on-unmatched"]
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.56.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@vercel/kv": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.12",
      "@types/react-dom": "^18.3.1"
    }
  }
}
