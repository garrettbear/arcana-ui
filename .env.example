# Server-side only. Never prefix with VITE_ (that would expose it to the browser bundle).
# Used by /api/generate-theme on Vercel.
ANTHROPIC_API_KEY=sk-ant-...

# Supabase credentials for the playground theme cache (arcana-ops-prod).
# Service role key must never reach the browser bundle. When either var is
# unset the cache layer soft-fails and every request calls Anthropic, which
# is the expected local-dev behavior.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
